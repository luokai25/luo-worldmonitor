# ============================================
# Luo World Monitor — Environment Variables
# ============================================
# All features are FREE and unlocked!
# Only set keys for data sources you want to use.
# The dashboard works without any keys for basic operation.
# ============================================

# ------ AI Summarization (Optional) ------

# Groq API (free tier: 14,400 req/day)
# Get yours at: https://console.groq.com/
GROQ_API_KEY=

# OpenRouter API (free tier: 50 req/day)
# Get yours at: https://openrouter.ai/
OPENROUTER_API_KEY=

# Ollama (local, free, unlimited)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama3


# ------ Market Data (Optional) ------

# Finnhub (free tier available)
# Register at: https://finnhub.io/
FINNHUB_API_KEY=


# ------ Economic Data (Optional) ------

# FRED (Federal Reserve Economic Data)
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=


# ------ Energy Data (Optional) ------

# U.S. Energy Information Administration
# Register at: https://www.eia.gov/opendata/
EIA_API_KEY=


# ------ Air Quality (Optional) ------

# OpenAQ API v3
# Register at: https://docs.openaq.org/using-the-api/api-key
OPENAQ_API_KEY=


# ------ Conflict Data (Optional) ------

# ACLED (free for researchers)
# Register at: https://acleddata.com/
ACLED_EMAIL=
ACLED_PASSWORD=

# UCDP (Uppsala Conflict Data Program)
# Register at: https://ucdp.uu.se/apidocs/
UCDP_ACCESS_TOKEN=


# ------ Satellite Fire Detection (Optional) ------

# NASA FIRMS
# Register at: https://firms.modaps.eosdis.nasa.gov/
NASA_FIRMS_API_KEY=


# ------ Aviation (Optional) ------

# AviationStack (live flight data)
# Register at: https://aviationstack.com/
AVIATIONSTACK_API=


# ------ Site Configuration ------

# Site variant: "full" (default)
VITE_VARIANT=full

# Map interaction mode: "flat" or "3d"
VITE_MAP_INTERACTION_MODE=3d


# ------ Self-Hosted Map Tiles (Optional) ------

# Leave empty to use free OpenFreeMap tiles
VITE_PMTILES_URL=


# ------ Public Data Sources (no keys needed!) ------

# UNHCR — public API, no auth
# Open-Meteo — public API, no auth
# WorldPop — public API, no auth
# ReliefWeb — public API, no auth

# ============================================
# THATS IT! No payment keys, no subscriptions!
# Everything is FREE and UNLOCKED!
# ============================================

